{
  "uid": "keinfs-io-drilldown",
  "title": "KeInFS — I/O Lifecycle Drill-Down",
  "tags": ["keinfs", "lifecycle", "drilldown"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      { "name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus", "current": { "text": "Prometheus", "value": "keinfs-prom" } },
      {
        "name": "service", "label": "Service", "type": "custom",
        "query": "kms,kas,kst", "current": { "text": "kms", "value": "kms" },
        "includeAll": false
      },
      {
        "name": "rpc", "label": "RPC", "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(keinfs_${service}_phase_latency_microseconds, rpc)",
        "refresh": 2, "includeAll": true, "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "instance", "label": "Instance", "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(keinfs_${service}_up, instance)",
        "refresh": 2, "includeAll": true, "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "links": [
    { "title": "Lifecycle Overview", "type": "link", "url": "/d/keinfs-io-lifecycle", "icon": "external link" }
  ],
  "panels": [
    {
      "type": "row", "title": "Per-phase latency for $service / rpc=$rpc", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries", "title": "Phase latency p99 (µs) — every phase, $service rpc=$rpc",
      "description": "One line per (rpc, phase). This is the authoritative phase decomposition of an I/O: where every microsecond of an operation is spent inside $service.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "µs", "custom": { "fillOpacity": 3, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max", "mean"] } },
      "targets": [
        { "expr": "max by (rpc, phase) (keinfs_${service}_phase_latency_microseconds{rpc=~\"$rpc\",instance=~\"$instance\",quantile=\"0.99\"})", "refId": "A", "legendFormat": "{{rpc}} / {{phase}}" }
      ]
    },
    {
      "type": "row", "title": "Percentile spread per phase", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 }
    },
    {
      "type": "heatmap", "title": "Phase latency heatmap (p50/p95/p99/max stacked by phase)",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "calculate": false, "cellGap": 1, "color": { "scheme": "Spectral", "mode": "scheme" } },
      "targets": [
        { "expr": "max by (phase) (keinfs_${service}_phase_latency_microseconds{rpc=~\"$rpc\",instance=~\"$instance\",quantile=\"0.99\"})", "refId": "A", "legendFormat": "{{phase}}", "format": "time_series" }
      ]
    },
    {
      "type": "table", "title": "Phase percentile table (latest, µs)",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns", "keepLabels": ["phase", "quantile"] } },
        { "id": "groupBy", "options": { "fields": {
          "phase": { "operation": "groupby" },
          "quantile": { "operation": "groupby" },
          "Value": { "operation": "lastNotNull", "aggregations": ["lastNotNull"] }
        } } }
      ],
      "targets": [
        { "expr": "max by (phase, quantile) (keinfs_${service}_phase_latency_microseconds{rpc=~\"$rpc\",instance=~\"$instance\"})", "refId": "A", "format": "table", "instant": true }
      ]
    },
    {
      "type": "row", "title": "RPC totals & error rate ($service)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },
    {
      "type": "timeseries", "title": "RPC request rate by rpc (ops/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } } },
      "targets": [
        { "expr": "sum by (rpc) (rate(keinfs_${service}_rpc_requests_total{instance=~\"$instance\"}[2m]))", "refId": "A", "legendFormat": "{{rpc}}" }
      ]
    },
    {
      "type": "timeseries", "title": "RPC error rate by rpc (errors/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 }, "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "sum by (rpc) (rate(keinfs_${service}_rpc_errors_total{instance=~\"$instance\"}[2m]))", "refId": "A", "legendFormat": "{{rpc}}" }
      ]
    }
  ]
}
