# Baseline environment file for the KST systemd runner.
# The quick-start generator appends concrete target values to copies of this
# file, because making operators type offsets by hand is a bad hobby.

KST_BIN={{KST_BIN}}
KST_LISTEN_BACKLOG=4096
KST_RECORD_MIX=extent-only
KST_EXTENT_BYTES=1048576
KST_PACKED_BYTES=16384
KST_READ_INGRESS_MODE=interrupt
KST_WRITE_INGRESS_MODE=busy
KST_READ_INGRESS_WORKERS=4
KST_WRITE_INGRESS_WORKERS=2
KST_READ_INGRESS_QUEUE_DEPTH=2048
KST_WRITE_INGRESS_QUEUE_DEPTH=2048
KST_DIRECT_READ_MODE=busy
KST_DIRECT_WRITE_MODE=busy
KST_DIRECT_READ_WORKERS=8
KST_DIRECT_WRITE_WORKERS=8
KST_DIRECT_READ_QUEUE_DEPTH=4096
KST_DIRECT_WRITE_QUEUE_DEPTH=4096
KST_H2_INITIAL_WINDOW_BYTES=8388608
KST_H2_MAX_CONCURRENT_STREAMS=512
KST_H2_MAX_SEND_BUFFER_BYTES=134217728
KST_STATS_ROOT={{KST_STATS_ROOT}}
KST_KIX_STATS_ROOT={{KIX_STATS_ROOT}}
